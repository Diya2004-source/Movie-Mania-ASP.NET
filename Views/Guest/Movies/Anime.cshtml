@{
    ViewData["Title"] = "Anime";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    body {
        background: #0f172a;
        font-family: Segoe UI;
        color: white;
    }

    /* HERO */

    .hero {
        background: linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.8)),url('/images/movies/banner.jpg');
        background-size: cover;
        background-position: center;
        height: 300px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        margin-bottom: 40px;
    }

        .hero h1 {
            font-size: 38px;
            font-weight: 700;
        }

    /* CARD */

    .show-card {
        background: #1e293b;
        border: none;
        border-radius: 12px;
        overflow: hidden;
        transition: .3s;
    }

        .show-card:hover {
            transform: translateY(-10px) scale(1.03);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

    .show-img {
        height: 260px;
        width: 100%;
        object-fit: cover;
    }

    .card-body {
        text-align: center;
    }

    .card-text {
        color: #cbd5f5;
    }

    /* RATING */

    .rating {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #facc15;
        color: black;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: 600;
    }

    /* BUTTON */

    .watch-btn {
        background: #e50914;
        border: none;
        width: 100%;
        font-weight: 600;
    }

        .watch-btn:hover {
            background: #ff1f2a;
        }

</style>

<div class="container mt-4">

    <div class="hero">

        <div>

            <h1>Popular Shows</h1>
            <p>Stream the best shows anytime</p>

        </div>

    </div>

    <div class="row g-4">

        <!-- SHOW 1 -->

        <div class="col-md-3">

            <div class="card show-card position-relative">

                <div class="rating">⭐ 8.7</div>

                <img src="~/images/movies/chhota_bheem.jpg" class="show-img">

                <div class="card-body">

                    <h5 class="card-title">Chhota Bheem</h5>

                    <p class="card-text">Imagination</p>

                    <button class="btn watch-btn" onclick="showQR()">Watch Now</button>

                </div>

            </div>

        </div>

        <!-- SHOW 2 -->

        <div class="col-md-3">

            <div class="card show-card position-relative">

                <div class="rating">⭐ 9.0</div>

                <img src="~/images/movies/mash_and_bear.jpg" class="show-img">

                <div class="card-body">

                    <h5 class="card-title">Masha and Bear</h5>

                    <p class="card-text">Fiction</p>

                    <button class="btn watch-btn" onclick="showQR()">Watch Now</button>

                </div>

            </div>

        </div>

        <!-- SHOW 3 -->

        <div class="col-md-3">

            <div class="card show-card position-relative">

                <div class="rating">⭐ 8.3</div>

                <img src="~/images/movies/paw_patrol.jpg" class="show-img">

                <div class="card-body">

                    <h5 class="card-title">Paw Patrol</h5>

                    <p class="card-text">Fictional</p>

                    <button class="btn watch-btn" onclick="showQR()">Watch Now</button>

                </div>

            </div>

        </div>

        <!-- SHOW 4 -->

        <div class="col-md-3">

            <div class="card show-card position-relative">

                <div class="rating">⭐ 8.1</div>

                <img src="~/images/movies/tom_jerry.jpg" class="show-img">

                <div class="card-body">

                    <h5 class="card-title">Tom and Jerry</h5>

                    <p class="card-text">Fictional</p>

                    <button class="btn watch-btn" onclick="showQR()">Watch Now</button>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- QR POPUP -->

<div id="qrModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:999;">

    <div style="background:white;width:350px;margin:8% auto;padding:25px;border-radius:12px;text-align:center;color:black;">

        <h4>Scan QR To Watch</h4>

        <img src="/images/payment/qr.jpg" width="220" />

        <br><br>

        <button class="btn btn-dark" onclick="closeQR()">Close</button>

    </div>

</div>

<script>

    function showQR(){
    document.getElementById("qrModal").style.display="block";
    }

    function closeQR(){
    document.getElementById("qrModal").style.display="none";
    }

</script>
