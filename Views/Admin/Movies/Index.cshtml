@model IEnumerable<MovieMania.Models.Movie>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4 text-white">

    <h2 class="mb-4">Movies List</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <a asp-action="Create" class="btn btn-primary mb-3">
        + Add New Movie
    </a>

    <table class="table table-dark table-striped table-bordered">

        <thead>
            <tr>
                <th>Thumbnail</th>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Duration</th>
                <th>Rating</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var movie in Model)
            {
                <tr>

                    <td>
                        @if (!string.IsNullOrEmpty(movie.Thumbnail))
                        {
                            <img src="~/images/movies/@movie.Thumbnail"
                                 width="100"
                                 style="border-radius:8px;" />
                        }
                    </td>

                    <td>@movie.Title</td>
                    <td>@movie.Genre</td>
                    <td>@movie.ReleaseYear</td>
                    <td>@movie.Duration min</td>
                    <td>@movie.Rating ⭐</td>

                    <td>

                        <a asp-action="Edit"
                           asp-route-id="@movie.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@movie.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>