@model MovieMania.Models.Movie

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-5">

    <div class="card card-dark p-4 shadow-lg">

        <h2 class="mb-4 text-center text-light">Add New Movie</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="Title" class="form-label text-light"></label>
                    <input asp-for="Title" class="form-control custom-input" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Genre" class="form-label text-light"></label>
                    <input asp-for="Genre" class="form-control custom-input" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ReleaseDate" class="form-label text-light"></label>
                    <input asp-for="ReleaseDate" type="date" class="form-control custom-input" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ReleaseYear" class="form-label text-light"></label>
                    <input asp-for="ReleaseYear" class="form-control custom-input" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Duration" class="form-label text-light"></label>
                    <input asp-for="Duration" class="form-control custom-input" />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Rating" class="form-label text-light"></label>
                    <input asp-for="Rating" class="form-control custom-input" />
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="Description" class="form-label text-light"></label>
                    <textarea asp-for="Description" class="form-control custom-input"></textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="VideoUrl" class="form-label text-light"></label>
                    <input asp-for="VideoUrl" class="form-control custom-input" />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label text-light">Upload Thumbnail</label>
                    <input type="file" name="ThumbnailFile" class="form-control custom-input" />
                </div>

            </div>

            <div class="text-center mt-3">
                <button type="submit" class="btn btn-success btn-custom">Add Movie</button>
                <a asp-action="Index" class="btn btn-outline-light btn-custom ms-2">Cancel</a>
            </div>

        </form>

    </div>

</div>

<style>

    body {
        background: #0f0f0f;
    }

    /* Card */
    .card-dark {
        background: #1c1c1c;
        border: none;
        border-radius: 12px;
        max-width: 900px;
        margin: auto;
    }

    /* Inputs */
    .custom-input {
        background: #2a2a2a;
        border: 1px solid #444;
        color: white;
        border-radius: 8px;
        padding: 10px;
    }

        .custom-input:focus {
            background: #2a2a2a;
            color: white;
            border-color: #0d6efd;
            box-shadow: 0 0 8px rgba(13,110,253,0.4);
        }

    /* Buttons */
    .btn-custom {
        padding: 8px 20px;
        border-radius: 8px;
        transition: 0.3s;
    }

    .btn-success {
        background: #00c853;
        border: none;
    }

        .btn-success:hover {
            background: #00e676;
        }

    .btn-outline-light:hover {
        background: white;
        color: black;
    }

</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}