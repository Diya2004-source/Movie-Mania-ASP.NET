@model MovieMania.Models.Movie

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4 text-white">

    <h2 class="mb-4">Edit Movie</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div class="row">

            <div class="col-md-6 mb-3">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Genre"></label>
                <input asp-for="Genre" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="ReleaseDate"></label>
                <input asp-for="ReleaseDate" type="date" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="ReleaseYear"></label>
                <input asp-for="ReleaseYear" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Duration"></label>
                <input asp-for="Duration" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Rating"></label>
                <input asp-for="Rating" class="form-control" />
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="VideoUrl"></label>
                <input asp-for="VideoUrl" class="form-control" />
            </div>

            <div class="col-md-12 mb-3">

                <label>Current Thumbnail</label><br />

                @if (!string.IsNullOrEmpty(Model.Thumbnail))
                {
                    <img src="~/images/movies/@Model.Thumbnail"
                         width="150"
                         style="border-radius:8px;" />
                }

            </div>

            <div class="col-md-12 mb-3">
                <label>Change Thumbnail</label>
                <input type="file" name="ThumbnailFile" class="form-control" />
            </div>

        </div>

        <button type="submit" class="btn btn-primary">Update Movie</button>

        <a asp-action="Index" class="btn btn-secondary">Cancel</a>

    </form>

</div>