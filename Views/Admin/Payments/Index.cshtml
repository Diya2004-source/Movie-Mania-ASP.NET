@model IEnumerable<MovieMania.Models.Payment>

@{
    ViewData["Title"] = "User Payments";
}

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container mt-4 text-white" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <h2 class="mb-4">User Payments</h2>

    <table class="table table-bordered table-hover table-dark text-white">
        <thead class="table-secondary text-dark">
            <tr>
                <th>User</th>
                <th>Amount ($)</th>
                <th>Payment Method</th>
                <th>Payment Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model)
            {
                <tr>
                    <td>@payment.User?.Name ?? "Unknown"</td>
                    <td>@payment.Amount</td>
                    <td>@payment.PaymentMethod</td>
                    <td>@payment.PaymentDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        <a class="btn btn-info btn-sm text-white" asp-action="Details" asp-route-id="@payment.Id">Details</a>
                        <a class="btn btn-danger btn-sm text-white" asp-action="Delete" asp-route-id="@payment.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>