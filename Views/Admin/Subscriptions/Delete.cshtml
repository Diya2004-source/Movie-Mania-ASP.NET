@model MovieMania.Models.SubscriptionPlan

@{
    ViewData["Title"] = "Delete Subscription Plan";
}

<h2>Delete Subscription Plan</h2>

<h4>Are you sure you want to delete this plan?</h4>

<div class="card p-3">
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Price:</strong> $@Model.Price</p>
    <p><strong>Duration:</strong> @Model.DurationDays days</p>
    <p><strong>Status:</strong> @Model.Status</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger mt-2">Delete</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a>
</form>