@model IEnumerable<MovieMania.Models.User>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="card card-dark p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold">Users Management</h2>
            <a href="/Users/Create" class="btn btn-primary">+ Create User</a>
        </div>

        <table class="table table-dark-custom table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th width="180">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @user.Role
                            </span>
                        </td>
                        <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/Users/Edit/@user.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/Users/Delete/@user.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>