
@model IEnumerable<MovieMania.Models.Offer>

    @{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="card card-dark p-4">

        <div class="d-flex justify-content-between mb-3">
            <h2>Offers Management</h2>
            <a href="/Offers/Create" class="btn btn-primary">+ Create Offer</a>
        </div>

        <table class="table table-dark-custom table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Discount %</th>
                    <th>Expiry</th>
                    <th width="180">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var offer in Model)
                {
                    <tr>
                        <td>@offer.Title</td>
                        <td>
                            <span class="badge bg-success">
                                @offer.DiscountPercentage %
                            </span>
                        </td>
                        <td>@offer.ExpiryDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <a href="/Offers/Edit/@offer.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/Offers/Delete/@offer.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>