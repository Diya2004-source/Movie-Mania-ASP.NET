<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieMania</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>

        /* ===== PAGE LAYOUT FOR STICKY FOOTER ===== */

        html, body {
            height: 100%;
        }

        body {
            background-color: #0A0C0F;
            color: #fff;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
        }

        /* NAVBAR */

        .navbar-dark-custom {
            background-color: #0A0C0F;
            border-bottom: 1px solid #1E1E1E;
        }

        .navbar-brand {
            font-size: 24px;
            font-weight: bold;
            color: #00E0FF !important;
        }

        .nav-link {
            color: #ccc !important;
            margin-left: 15px;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #00E0FF !important;
            }

        /* LOGIN BUTTON */

        .btn-login {
            background: transparent;
            border: 1px solid #00E0FF;
            color: #00E0FF;
            margin-left: 15px;
        }

            .btn-login:hover {
                background: #00E0FF;
                color: #000;
            }

        .btn-register {
            background: #4A80F0;
            border: none;
            margin-left: 10px;
        }

            .btn-register:hover {
                background: #00E0FF;
                color: #000;
            }

        /* FOOTER */

        .footer-ott {
            background-color: #0A0C0F;
            border-top: 1px solid #1E1E1E;
            padding: 40px 0;
            color: #aaa;
        }

            .footer-ott h5 {
                color: #fff;
                margin-bottom: 15px;
            }

        .footer-links {
            list-style: none;
            padding: 0;
        }

            .footer-links li {
                margin-bottom: 8px;
            }

            .footer-links a {
                text-decoration: none;
                color: #aaa;
                transition: 0.3s;
            }

                .footer-links a:hover {
                    color: #00E0FF;
                }

        .social-icons a {
            color: #aaa;
            font-size: 20px;
            margin-right: 10px;
            transition: 0.3s;
        }

            .social-icons a:hover {
                color: #00E0FF;
            }

        footer hr {
            border-color: #222;
        }

    </style>

</head>

<body>

    <!-- NAVBAR -->

    <nav class="navbar navbar-expand-lg navbar-dark navbar-dark-custom">

        <div class="container">

            <a class="navbar-brand" asp-controller="GuestHome" asp-action="Index">
                 MovieMania
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuestHome" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuestMovies" asp-action="Movies">Movies</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuestMovies" asp-action="Shows">Shows</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="GuestMovies" asp-action="Anime">Anime</a>
                    </li>

                    <li class="nav-item">
                        <a class="btn btn-login" asp-controller="Auth" asp-action="Login">Login</a>
                    </li>

                    <li class="nav-item">
                        <a class="btn btn-register" asp-controller="Auth" asp-action="Register">Register</a>
                    </li>

                </ul>

            </div>

        </div>

    </nav>


    <!-- PAGE CONTENT -->

    <div class="container mt-4 main-content">

        <main role="main">
            @RenderBody()
        </main>

    </div>


    <!-- FOOTER -->

    <footer class="footer-ott">

        <div class="container">

            <div class="row">

                <!-- ABOUT -->
                <div class="col-md-3">
                    <h5>MovieMania</h5>
                    <p>
                        Stream the latest movies, TV shows, and anime online.
                        Discover trending content and enjoy unlimited entertainment.
                    </p>
                </div>

                <!-- QUICK LINKS -->
                <div class="col-md-3">
                    <h5>Quick Links</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="GuestHome" asp-action="Index">Home</a></li>
                        <li><a asp-controller="GuestMovies" asp-action="Movies">Movies</a></li>
                        <li><a asp-controller="GuestMovies" asp-action="Shows">Shows</a></li>
                        <li><a asp-controller="GuestMovies" asp-action="Anime">Anime</a></li>
                    </ul>
                </div>

                <!-- GENRES -->
                <div class="col-md-3">
                    <h5>Genres</h5>
                    <ul class="footer-links">
                        <li>Action</li>
                        <li>Comedy</li>
                        <li>Drama</li>
                        <li>Horror</li>
                        <li>Sci-Fi</li>
                    </ul>
                </div>

                <!-- CONTACT -->
                <div class="col-md-3">
                    <h5>Contact</h5>
                    <p>Email: support@moviemania.com</p>
                    <p>Phone: +91 98765 43210</p>

                    <div class="social-icons">

                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>

                    </div>

                </div>

            </div>

            <hr>

            <div class="text-center">
                © 2026 MovieMania • All Rights Reserved
            </div>

        </div>

    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>